# Kopioi tämä tiedostoksi .env ja täytä arvot (paikallista kehitystä varten).
# Netlifyssä samat arvot asetetaan Site settings -> Environment variables.

# Supabase-projektin tiedot (Supabase -> Project Settings -> API)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Yhteinen perhe-PIN (mitä tahansa numeroita/merkkejä)
VITE_FAMILY_PIN=1234

# Anthropic API -avain – VAIN Netlify-funktiolle, EI selaimeen.
# Tätä EI laiteta .env-tiedostoon tuotannossa vaan Netlifyn ympäristömuuttujiin.
ANTHROPIC_API_KEY=sk-ant-...
